# Must match the cluster your wallet uses, or balances will not match what you expect.
# Devnet (Phantom "Devnet"):
VITE_SOLANA_RPC=https://api.devnet.solana.com
# Testnet (different chain from Devnet):
# VITE_SOLANA_RPC=https://api.testnet.solana.com

# Optional: local keypair JSON array for dev signing; not needed if you only use Phantom.
# VITE_LOCAL_KEYPAIR_JSON=[...]
